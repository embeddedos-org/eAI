{
    "version": 6,
    "cmakeMinimumRequired": { "major": 3, "minor": 16, "patch": 0 },
    "configurePresets": [
        {
            "name": "linux-x64-debug",
            "displayName": "Linux x64 Debug",
            "binaryDir": "${sourceDir}/build/linux-x64-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "EAI_BUILD_TESTS": "ON",
                "EAI_BUILD_ACCEL": "ON",
                "EAI_BUILD_FORMATS": "ON"
            },
            "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" }
        },
        {
            "name": "linux-x64-release",
            "displayName": "Linux x64 Release",
            "binaryDir": "${sourceDir}/build/linux-x64-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "EAI_BUILD_TESTS": "OFF",
                "EAI_BUILD_ACCEL": "ON",
                "EAI_BUILD_FORMATS": "ON"
            },
            "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" }
        },
        {
            "name": "linux-arm64-release",
            "displayName": "Linux ARM64 Release (cross)",
            "binaryDir": "${sourceDir}/build/linux-arm64-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/toolchain-arm-cortex-a-linux.cmake",
                "EAI_BUILD_TESTS": "OFF"
            },
            "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" }
        },
        {
            "name": "windows-x64-debug",
            "displayName": "Windows x64 Debug",
            "binaryDir": "${sourceDir}/build/windows-x64-debug",
            "generator": "Visual Studio 17 2022",
            "architecture": { "value": "x64" },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "EAI_BUILD_TESTS": "ON",
                "EAI_BUILD_ACCEL": "ON",
                "EAI_BUILD_FORMATS": "ON"
            },
            "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" }
        },
        {
            "name": "windows-x64-release",
            "displayName": "Windows x64 Release",
            "binaryDir": "${sourceDir}/build/windows-x64-release",
            "generator": "Visual Studio 17 2022",
            "architecture": { "value": "x64" },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "EAI_BUILD_TESTS": "OFF"
            },
            "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" }
        },
        {
            "name": "macos-x64-release",
            "displayName": "macOS x64 Release",
            "binaryDir": "${sourceDir}/build/macos-x64-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_OSX_ARCHITECTURES": "x86_64"
            },
            "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Darwin" }
        },
        {
            "name": "macos-arm64-release",
            "displayName": "macOS ARM64 Release",
            "binaryDir": "${sourceDir}/build/macos-arm64-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_OSX_ARCHITECTURES": "arm64"
            },
            "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Darwin" }
        },
        {
            "name": "cortex-m4-release",
            "displayName": "Cortex-M4 Release",
            "binaryDir": "${sourceDir}/build/cortex-m4-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/toolchain-arm-cortex-m4.cmake",
                "EAI_HAL_THREAD": "OFF",
                "EAI_HAL_FS": "OFF",
                "EAI_HAL_NET": "OFF",
                "EAI_BUILD_CLI": "OFF",
                "EAI_BUILD_BCI": "OFF",
                "EAI_BUILD_FRAMEWORK": "OFF",
                "EAI_BUILD_FORMATS": "OFF"
            }
        },
        {
            "name": "cortex-m7-release",
            "displayName": "Cortex-M7 Release",
            "binaryDir": "${sourceDir}/build/cortex-m7-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/toolchain-arm-cortex-m7.cmake",
                "EAI_HAL_THREAD": "OFF",
                "EAI_HAL_FS": "OFF",
                "EAI_HAL_NET": "OFF",
                "EAI_BUILD_CLI": "OFF",
                "EAI_BUILD_BCI": "OFF",
                "EAI_BUILD_FRAMEWORK": "OFF",
                "EAI_BUILD_FORMATS": "OFF"
            }
        },
        {
            "name": "container-x64-release",
            "displayName": "Container x64 Release",
            "binaryDir": "${sourceDir}/build/container-x64-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "EAI_PLATFORM_CONTAINER": "ON",
                "EAI_BUILD_TESTS": "ON"
            },
            "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" }
        }
    ],
    "buildPresets": [
        { "name": "linux-x64-debug", "configurePreset": "linux-x64-debug" },
        { "name": "linux-x64-release", "configurePreset": "linux-x64-release" },
        { "name": "windows-x64-debug", "configurePreset": "windows-x64-debug", "configuration": "Debug" },
        { "name": "windows-x64-release", "configurePreset": "windows-x64-release", "configuration": "Release" },
        { "name": "macos-arm64-release", "configurePreset": "macos-arm64-release" },
        { "name": "cortex-m4-release", "configurePreset": "cortex-m4-release" }
    ],
    "testPresets": [
        { "name": "linux-x64-debug", "configurePreset": "linux-x64-debug", "output": { "outputOnFailure": true } },
        { "name": "windows-x64-debug", "configurePreset": "windows-x64-debug", "configuration": "Debug", "output": { "outputOnFailure": true } }
    ]
}
